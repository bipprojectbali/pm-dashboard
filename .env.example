# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pm-dashboard
DIRECT_URL=postgresql://user:password@localhost:5432/pm-dashboard

# Dev Inspector
REACT_EDITOR=code
PORT=3111

# Redis
REDIS_URL=redis://localhost:6379

# Claude Code Telegram Notification
TELEGRAM_NOTIFY_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3111

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SUPER_ADMIN_EMAIL=admin@example.com

# pm-watch webhook (ActivityWatch ingestion)
# Set to a long random string — every pmw agent uses this as its Bearer token.
PMW_WEBHOOK_TOKEN=
PMW_EVENT_BATCH_MAX=500

# MCP server auth (see src/app.ts /mcp and scripts/mcp/server.ts)
# Single shared secret. Scope is derived from NODE_ENV:
#   NODE_ENV=production → readonly (query tools only)
#   anything else       → admin   (write + dev tools)
# The cap is enforced in code (createMcpServer), not by config.
MCP_SECRET=

# GitHub webhook (per-project repo activity)
# Shared HMAC secret — paste into each repo's webhook setting.
# Endpoint: POST /webhooks/github, content-type application/json.
GITHUB_WEBHOOK_SECRET=

# deploy-stg MCP (scripts/mcp-deploy/server.ts)
# GH_TOKEN — used by the gh CLI to dispatch Publish/Re-Pull workflows non-interactively.
#            Personal access token with `workflow` scope (classic) or fine-grained equivalent.
# STG_BASE_URL — base URL polled by verify_stg / release_stg /api/version checks.
# STACK_NAME — Portainer stack base name; combined with stack_env (e.g. "pm-dashboard-stg").
GH_TOKEN=
STG_BASE_URL=https://pm-dashboard.wibudev.com
STACK_NAME=pm-dashboard

# SHADOW_DATABASE_URL — empty throwaway DB used by `prisma migrate diff` for the
# migration-drift gate in check_migrations / deploy_stg. Create a separate empty
# database (e.g. `CREATE DATABASE pm_shadow;`) and point this at it.
SHADOW_DATABASE_URL=postgresql://user:password@localhost:5432/pm_shadow
