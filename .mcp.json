{
  "mcpServers": {
    "playwright": {
      "command": "bunx",
      "args": ["@playwright/mcp@latest"]
    },
    "pm-dashboard": {
      "command": "bun",
      "args": ["run", "scripts/mcp/server.ts"],
      "env": {
        "MCP_SECRET": "${MCP_SECRET}"
      }
    },
    "deploy-stg": {
      "command": "bun",
      "args": ["run", "scripts/mcp-deploy/server.ts"]
    },
    "pm-dashboard-stg": {
      "type": "http",
      "url": "https://pm-dashboard.wibudev.com/mcp",
      "headers": {
        "Authorization": "Bearer ${MCP_SECRET}"
      }
    }
  }
}
